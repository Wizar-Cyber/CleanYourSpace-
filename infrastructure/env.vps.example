# Copy this file to the repository root as .env on the VPS.
# Replace every CHANGE_ME value before running deployment.

API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=512

DB_HOST=postgres
DB_PORT=5432
DB_NAME=corecon
DB_USER=corecon
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=corecon
MINIO_SECRET_KEY=CHANGE_ME_STRONG_MINIO_SECRET
MINIO_BUCKET=corecon-photos
MINIO_USE_SSL=false

SMTP_HOST=CHANGE_ME_SMTP_HOST
SMTP_PORT=587
SMTP_USER=CHANGE_ME_SMTP_USER
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=notifications@corecon.us

CLEANER_APP_URL=https://cleaner.corecon.us
ADMIN_PANEL_URL=https://admin.corecon.us
VITE_API_URL=https://api.corecon.us

BULL_PREFIX=bull
BULL_DEFAULT_JOBS=10

# Override only if the production branch changes.
DEPLOY_BRANCH=master

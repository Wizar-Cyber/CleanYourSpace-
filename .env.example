# Corecon Cleaning System — Environment Variables
# Copy to .env and fill in your values

# API
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=corecon
DB_USER=corecon
DB_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=corecon
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=corecon-photos
MINIO_USE_SSL=false

# SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@corecon.us

# Frontend URLs
CLEANER_APP_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:5174

# BullMQ
BULL_PREFIX=bull
BULL_DEFAULT_JOBS=10
